# ----------------------------------------------------------------------------
# Chef P's Kitchen — environment variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored. NEVER commit real keys.
# ----------------------------------------------------------------------------

# Public site URL (no trailing slash). Used for canonical URLs, OG tags, sitemap.
# Local dev: http://localhost:3000 — Production: your *.vercel.app URL for now,
# later https://chefpskitchen.co.uk
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Enquiry delivery (Web3Forms) ---------------------------------------------
# The enquiry form emails each submission to your inbox via Web3Forms.
# Get a free access key at https://web3forms.com (enter the email you want
# enquiries sent to; they email you the key). Paste it here. No database needed.
#
# This is NEXT_PUBLIC_ on purpose: Web3Forms' free plan only accepts submissions
# from the browser, and the access key is public by design (it just identifies
# which inbox to email). Spam is handled by the form's honeypots + any captcha
# you enable in the Web3Forms dashboard. Without this key the form still
# validates but shows a "please email us" message.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
