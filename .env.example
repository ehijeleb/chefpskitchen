# ----------------------------------------------------------------------------
# Chef P's Kitchen — environment variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored. NEVER commit real keys.
# ----------------------------------------------------------------------------

# Public site URL (no trailing slash). Used for canonical URLs, OG tags, sitemap.
# Local dev: http://localhost:3000 — Production: your *.vercel.app URL for now,
# later https://chefpskitchen.co.uk
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase -----------------------------------------------------------------
# Project URL + publishable (anon) key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key is SERVER-ONLY. It bypasses Row Level Security and must never
# be prefixed with NEXT_PUBLIC_ or referenced in any client component.
SUPABASE_SERVICE_ROLE_KEY=

# --- Email notifications (optional) -------------------------------------------
# New-enquiry email is OFF unless BOTH the flag is "true" AND a Resend key is set.
# Leave these unset and the site still works — submissions just save to Supabase.
ENQUIRY_NOTIFICATIONS_ENABLED=false
RESEND_API_KEY=
ENQUIRY_NOTIFICATION_TO=hello@chefpskitchen.co.uk
ENQUIRY_NOTIFICATION_FROM=enquiries@chefpskitchen.co.uk
